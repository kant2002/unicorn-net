<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Version>1.0.0</Version>

    <GenerateDocumentationFile Condition=" '$(Configuration)' == 'Release' ">True</GenerateDocumentationFile>

    <Description>.NET binding/wrapper for the Unicorn engine.</Description>
    <Copyright>Copyright 2018 (c) FICTURE7</Copyright>
    <Authors>FICTURE7</Authors>

    <PackageTags>unicorn wrapper binding</PackageTags>

    <PackageProjectUrl>https://github.com/kant2002/unicorn-net</PackageProjectUrl>
    <PackageLicenseUrl>$(PackageProjectUrl)/blob/master/LICENSE</PackageLicenseUrl>

    <RepositoryUrl>$(PackageProjectUrl).git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
